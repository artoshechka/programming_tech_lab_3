%% Диаграмма пакетов: модули и их зависимости.
%% Границы ответственности подписаны в комментариях у каждого узла.
graph TD
    main["main<br/>(точка входа)"]
    gui["gui<br/>View + ChartModel + композиция"]
    ioc["ioc_container<br/>DI-контейнер"]
    chart["chart<br/>построители графиков + агрегация"]
    style_pkg["style<br/>палитры и темы графика"]
    parser["parser<br/>загрузка данных по расширению"]
    database["database_module<br/>доступ к SQLite"]
    data_model["data_model<br/>доменная модель TimelineData"]
    logger["logger<br/>логирование (без Qt)"]

    main --> gui
    gui --> chart
    gui --> style_pkg
    gui --> parser
    gui --> database
    gui --> data_model
    gui --> logger
    gui --> ioc

    chart --> data_model
    chart --> style_pkg
    chart --> logger

    style_pkg --> logger

    parser --> data_model
    parser --> database
    parser --> logger

    database --> logger
