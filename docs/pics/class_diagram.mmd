%% Диаграмма классов: ключевые сущности, их члены и связи.
%% Классы сгруппированы по модулям (namespace) для наглядности.
%% Обозначения: ..|> реализация интерфейса, --|> наследование,
%% o-- агрегация (ссылка/shared), *-- композиция (владение), --> / ..> использование.
classDiagram

    namespace logger {
        class ILogger {
            <<interface>>
            +Log(entry) void
            +SetSettings(settings) void
            +GetSettings() Settings
        }
        class ThreadSafeLogger {
            +Log(entry) void
            +SetSettings(settings) void
            +GetSettings() Settings
        }
        class LogEntryStream {
            +operator<<(value) LogEntryStream&
            -ILogger* logger_
        }
    }

    namespace data_model {
        class TimelineData {
            +string name_
            +vector~TimePoint~ points_
        }
        class TimePoint {
            +string time_
            +double value_
        }
    }

    namespace parser {
        class IParser {
            <<interface>>
            +Load(source) TimelineData
            +ListSubSources(path) vector~string~
        }
        class ParserBase {
            <<abstract>>
            +Load(source) TimelineData
        }
        class JsonParser
        class DatabaseParser {
            -IDatabaseManager* manager_
        }
        class IParserRegistry {
            <<interface>>
            +Get(ext) IParser*
            +Register(ext, parser) void
            +SupportedExtensions() vector~string~
        }
        class ParserRegistry
    }

    namespace database_module {
        class IDatabase {
            <<interface>>
            +Open(path) bool
            +Tables() vector~string~
            +Query(sql) Rows
        }
        class IDatabaseManager {
            <<interface>>
            +Create(path) IDatabase
        }
        class SqliteDB
        class SqliteDBManager
    }

    namespace chart {
        class BuilderOptions {
            +bool aggregate
            +IPalette* palette
        }
        class IChartBuilder {
            <<interface>>
            +Configure(options) void
            +Build(data) unique_ptr~QChart~
        }
        class BarChartBuilder {
            +Configure(options) void
            +Build(data) unique_ptr~QChart~
            -IPalette* palette_
            -ILogger logger_
        }
        class PieChartBuilder {
            +Configure(options) void
            +Build(data) unique_ptr~QChart~
            -IPalette* palette_
            -ILogger logger_
        }
        class LineChartBuilder {
            +Configure(options) void
            +Build(data) unique_ptr~QChart~
            -IPalette* palette_
            -ILogger logger_
        }
        class AreaChartBuilder {
            +Configure(options) void
            +Build(data) unique_ptr~QChart~
            -IPalette* palette_
            -ILogger logger_
        }
        class GanttChartBuilder {
            +Configure(options) void
            +Build(data) unique_ptr~QChart~
            -IPalette* palette_
            -ILogger logger_
        }
    }

    namespace style {
        class IPalette {
            <<interface>>
            +ColorFor(index, total) QColor
        }
        class IChartStyle {
            <<interface>>
            +Apply(chart) void
        }
        class ColorStyle {
            +ColorFor(index, total) QColor
            +Apply(chart) void
        }
        class GrayscaleStyle {
            +ColorFor(index, total) QColor
            +Apply(chart) void
        }
    }

    namespace gui {
        class MainWindow {
            +MainWindow(builders, styles, registry, logger)
            +onFileSelected(index) void
            +onChooseFolder() void
            +onSavePdf() void
            +refresh() void
            +onError(message) void
            +toggleTheme() void
            +applyTheme() void
            -setRoot(path) void
            -loadFile(path) void
            -buildChart(data) unique_ptr~QChart~
            -setChart(chart) void
            -installRowWidgets(parent) void
            -updateRowSelection() void
            -ChartModel model_
            -QTreeView treeView_
            -QChartView chartView_
            -FileItemDelegate fileDelegate_
            -QColor accent_
            -bool darkTheme_
        }
        class ChartModel {
            +data() TimelineData&
            +hasData() bool
            +builder() string&
            +style() string&
            +aggregate() bool
            +listSubSources(path) vector~string~
            +setSource(source) void
            +setBuilder(builder) void
            +setStyle(style) void
            +setAggregate(on) void
            +dataChanged() signal
            +renderOptionsChanged() signal
            +errorOccurred(message) signal
            -IParserRegistry registry_
            -ILogger logger_
            -string builder_
            -string style_
            -bool aggregate_
        }
        class FileItemDelegate {
            +sizeHint(option, index) QSize
            +paint(painter, option, index) void
        }
        class FileRowWidget {
            +setSelected(selected) void
            +applyTheme(dark, accent) void
            +index() QModelIndex
            -updateColors() void
            -FileKind kind_
            -bool selected_
            -QColor accent_
            -GlyphIcon icon_
            -QLabel nameLabel_
            -QLabel sizeLabel_
            -QLabel dateLabel_
        }
        class GlyphIcon {
            +setColor(color) void
            #paintEvent(event) void
            -FileKind kind_
            -QColor color_
        }
        class ScrollableChartView {
            #wheelEvent(event) void
            #mousePressEvent(event) void
            #mouseMoveEvent(event) void
            #mouseReleaseEvent(event) void
            #mouseDoubleClickEvent(event) void
            -bool panning_
            -QPoint lastPos_
        }
        class TableSelectDialog {
            +selectedTable() QString
            -QListWidget list_
        }
        class FileKind {
            <<enumeration>>
            Folder
            Json
            Sqlite
            Generic
        }
    }

    %% ---- реализации и наследование ----
    ThreadSafeLogger ..|> ILogger
    ParserBase ..|> IParser
    JsonParser --|> ParserBase
    DatabaseParser --|> ParserBase
    ParserRegistry ..|> IParserRegistry
    SqliteDB ..|> IDatabase
    SqliteDBManager ..|> IDatabaseManager
    BarChartBuilder ..|> IChartBuilder
    PieChartBuilder ..|> IChartBuilder
    LineChartBuilder ..|> IChartBuilder
    AreaChartBuilder ..|> IChartBuilder
    GanttChartBuilder ..|> IChartBuilder
    IChartStyle --|> IPalette
    ColorStyle ..|> IChartStyle
    GrayscaleStyle ..|> IChartStyle
    ScrollableChartView --|> QChartView

    %% ---- агрегация / композиция / использование ----
    LogEntryStream o-- ILogger
    TimelineData *-- TimePoint
    ParserRegistry o-- IParser
    DatabaseParser o-- IDatabaseManager
    IParser --> TimelineData
    SqliteDBManager --> IDatabase : creates
    IChartBuilder --> TimelineData
    IChartBuilder --> IPalette
    IChartBuilder ..> BuilderOptions
    MainWindow *-- ChartModel
    MainWindow *-- FileItemDelegate
    MainWindow o-- IChartBuilder
    MainWindow o-- IChartStyle
    MainWindow o-- IParserRegistry
    MainWindow o-- ILogger
    MainWindow ..> FileRowWidget : creates
    MainWindow ..> ScrollableChartView
    MainWindow ..> TableSelectDialog : creates
    FileItemDelegate ..> FileRowWidget
    FileRowWidget *-- GlyphIcon
    FileRowWidget ..> FileKind
    ChartModel o-- IParserRegistry
    ChartModel o-- ILogger
    ChartModel *-- TimelineData
